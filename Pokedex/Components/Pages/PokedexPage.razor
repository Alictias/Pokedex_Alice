@page "/pokedex"

@rendermode Microsoft.AspNetCore.Components.Web.RenderMode.InteractiveServer
@* @rendermode InteractiveServer*@

@*
@using System.Linq
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Web*@
@using Pokedex.Data
@using Pokedex.Models
@using Pokedex.Services
@inject IPokeApiClient Poke
@inject ITeamService Team

<div class="pokedex-page">
    <h3 class="mb-3">Pokédex (@AppConstants.MinId-@AppConstants.MaxId)</h3>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div class="input-group" style="max-width: 380px;">
            <input class="form-control" @bind="searchText" placeholder="Nome contém..." />
            <button class="btn btn-primary" @onclick="() => ApplySearch(true)">Buscar</button>
        </div>

        <div class="btn-group" role="group" aria-label="Paginação">
            <button class="btn btn-outline-secondary" @onclick="PrevPage" disabled="@(!CanPrev)">◀</button>
            <span class="btn btn-outline-dark disabled">Página @pageIndex / @TotalPages</span>
            <button class="btn btn-outline-secondary" @onclick="NextPage" disabled="@(!CanNext)">▶</button>
        </div>
    </div>

    @if (loading)
    {
        <div class="alert alert-info mb-0">Carregando...</div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var p in pageData)
            {
                <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                    <div class="card h-100 shadow-sm">
                        <!-- Imagem oficial (já vem do model via URL official-artwork) -->
                        <img src="@p.ImageUrl" class="pokedexPage-img" alt="Sprite de @p.Name" loading="lazy" />
                        <div class="card-body">
                            <h5 class="card-title mb-1">#@p.Id @p.Name</h5>
                            <p class="mb-2">
                                @foreach (var t in p.Types)
                                {
                                    <span class="badge bg-secondary me-1">@t</span>
                                }
                            </p>
                            <small class="text-muted">Altura: @p.Height • Peso: @p.Weight</small>
                        </div>
                        <div class="card-footer bg-white">
                            <button class="btn btn-sm btn-primary w-100" @onclick="() => AddToTeam(p.Id)">
                                Adicionar ao Time
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    @if (!string.IsNullOrEmpty(alertMsg))
    {
        <div class="alert alert-@alertType mt-3">@alertMsg</div>
    }

   @code {
    // --- estado geral ---
    private string searchText = "";
    private int pageSize = 24;
    private int pageIndex = 1;
    private bool loading = true;


    // --- dados ---
    private List<PokemonBasic> allData = new(); // todos os Pokémon
    private List<PokemonBasic> pageData = new(); // página atual

    // --- alertas ---
    private string? alertMsg;
    private string alertType = "info";

    // --- helpers de paginação ---
    private int TotalPages => (int)Math.Ceiling((double)FilteredData.Count() / pageSize);
    private bool CanPrev => pageIndex > 1;
    private bool CanNext => pageIndex < TotalPages;

    // --- lista filtrada ---
    private IEnumerable<PokemonBasic> FilteredData =>
        string.IsNullOrWhiteSpace(searchText)
            ? allData
            : allData.Where(p => p.Name.Contains(searchText.Trim(), StringComparison.OrdinalIgnoreCase));

    // --- inicialização ---
    protected override async Task OnInitializedAsync()
    {
        await LoadAllData();
    }

    // --- carregar todos os Pokémon ---
    private async Task LoadAllData()
    {
        loading = true;

        if (!allData.Any())
        {
            var ids = Enumerable.Range(AppConstants.MinId, AppConstants.MaxId - AppConstants.MinId + 1);
            const int parallel = 8;

            foreach (var batch in ids.Chunk(parallel))
            {
                var tasks = batch.Select(id => Poke.GetBasicAsync(id));
                var results = await Task.WhenAll(tasks);
                allData.AddRange(results.Where(r => r is not null)!);
            }
        }

        ApplySearch();
        loading = false;
        StateHasChanged();
    }

    // --- aplicar filtro e paginação ---
    private void ApplySearch(bool resetPage = true)
    {
        if (resetPage) pageIndex = 1;

        pageData = FilteredData
            .Skip((pageIndex - 1) * pageSize)
            .Take(pageSize)
            .ToList();
    }

    // --- navegação ---
    private void PrevPage() { if (CanPrev) { pageIndex--; ApplySearch(false); } }
    private void NextPage() { if (CanNext) { pageIndex++; ApplySearch(false); } }

    // --- adicionar ao time ---
    private async Task AddToTeam(int id)
    {
        var (ok, error) = await Team.AddAsync(new TeamMember { PokemonId = id });
        if (ok) Show("success", "Adicionado ao time!");
        else Show("warning", error ?? "Não foi possível adicionar.");
    }

    // --- modal --- teste para selecionar info dos pokemons. Abandonado por falta de tempo
    @* private async Task OpenModal(int id)
    {
        selectedPokemon = await Poke.GetFullAsync(id); // método que busca detalhes completos
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
        selectedPokemon = null;
    } *@

    // --- alertas ---
    private void Show(string type, string msg) { alertType = type; alertMsg = msg; }
}
</div>